{
    "id": "message-scheduler",
    "name": "Agendador de Mensagens",
    "version": "1.0.0",
    "description": "Agende mensagens para serem enviadas automaticamente",
    "author": "Sistema Afiliados",
    "icon": "📅",
    "category": "automation",
    "requiredPlan": "growth",
    "permissions": [
        "whatsapp.send",
        "storage.write"
    ],
    "actions": [
        {
            "id": "schedule",
            "name": "Agendar Mensagem",
            "params": {
                "instanceId": "string",
                "jid": "string",
                "text": "string",
                "scheduledTime": "timestamp"
            }
        },
        {
            "id": "list",
            "name": "Listar Agendamentos"
        },
        {
            "id": "cancel",
            "name": "Cancelar Agendamento",
            "params": {
                "scheduleId": "string"
            }
        }
    ]
}