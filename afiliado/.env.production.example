# ========================================
# Configuração de Produção - Sistema Afiliados
# ========================================

# ----------------------------------------
# JWT Secret (OBRIGATÓRIO)
# ----------------------------------------
# Gere um secret seguro: openssl rand -base64 32
# IMPORTANTE: Deve ser o mesmo em VPS e Core
JWT_SECRET=seu-secret-super-seguro-mude-em-producao

# ----------------------------------------
# VPS Configuration
# ----------------------------------------
# Chave Privada RSA para assinatura (VPS)
# Gere: openssl genrsa 2048
PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
MIIEpAIBAAKCAQEA...
-----END RSA PRIVATE KEY-----"

# Chave Pública RSA para verificação (Core)
# Gere: openssl rsa -in private.pem -pubout
VPS_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...
-----END PUBLIC KEY-----"

# ----------------------------------------
# Database Configuration (PostgreSQL)
# ----------------------------------------
DB_PASSWORD=mude-esta-senha-em-producao
DATABASE_URL=postgresql://afiliados:${DB_PASSWORD}@db:5432/afiliados_licenses

# ----------------------------------------
# Redis Configuration
# ----------------------------------------
REDIS_PASSWORD=mude-esta-senha-redis
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ----------------------------------------
# PAPI WhatsApp Configuration
# ----------------------------------------
# URL da sua instalação PAPI
PAPI_URL=https://papi.sxconnect.com.br

# API Key da PAPI
PAPI_API_KEY=sua-chave-papi-aqui

# Instância padrão (opcional)
PAPI_INSTANCE=instance_default

# ----------------------------------------
# Domínios (Traefik)
# ----------------------------------------
# VPS License Server
VPS_DOMAIN=vps.afiliados.sxconnect.com.br

# Core Engine API
CORE_DOMAIN=api.afiliados.sxconnect.com.br

# UI Web Application
UI_DOMAIN=app.afiliados.sxconnect.com.br

# ----------------------------------------
# Quota Configuration
# ----------------------------------------
DEFAULT_QUOTA_FREE=10
DEFAULT_QUOTA_BASIC=100
DEFAULT_QUOTA_GROWTH=500
DEFAULT_QUOTA_PRO=999999

# ----------------------------------------
# Admin Configuration
# ----------------------------------------
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=mude-esta-senha-admin

# ----------------------------------------
# Monitoring (opcional)
# ----------------------------------------
# Sentry DSN para error tracking
SENTRY_DSN=

# New Relic License Key
NEW_RELIC_LICENSE_KEY=

# ----------------------------------------
# Backup Configuration (opcional)
# ----------------------------------------
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
S3_BUCKET=afiliados-backups
S3_ACCESS_KEY=
S3_SECRET_KEY=
