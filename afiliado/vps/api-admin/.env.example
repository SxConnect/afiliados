# Server
NODE_ENV=production
PORT=4001

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=licenses_db
DB_USER=licenses_user
DB_PASSWORD=your_secure_password_here

# JWT
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=24h

# Admin Panel
ADMIN_CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
