# Environment Variables para Produção - VPS License Server v2.0.0
# Copie este arquivo para .env e preencha os valores

# ============================================
# SECRETS (GERAR VALORES FORTES)
# ============================================

# JWT Secret (gerar com: openssl rand -base64 32)
JWT_SECRET=GERAR_VALOR_AQUI_32_CARACTERES_MINIMO

# License Secret (gerar com: openssl rand -base64 32)
LICENSE_SECRET=GERAR_VALOR_AQUI_32_CARACTERES_MINIMO

# Database Password (senha forte)
DB_PASSWORD=SENHA_FORTE_DO_POSTGRES

# Redis Password (senha forte)
REDIS_PASSWORD=SENHA_FORTE_DO_REDIS

# ============================================
# COMANDOS PARA GERAR SECRETS
# ============================================
#
# Linux/Mac:
#   openssl rand -base64 32
#
# Windows PowerShell:
#   -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 32 | % {[char]$_})
#
# Online (use com cuidado):
#   https://www.random.org/strings/
#
# ============================================

# ============================================
# EXEMPLO DE .env PREENCHIDO
# ============================================
#
# JWT_SECRET=xK9mP2vL8nQ4wR7tY5uI3oP6aS1dF0gH
# LICENSE_SECRET=zX8cV7bN6mM5kL4jH3gF2dS1aQ0wE9rT
# DB_PASSWORD=MyStr0ng!P@ssw0rd#2024
# REDIS_PASSWORD=R3d1s!S3cur3#P@ss2024
#
# ============================================

# ============================================
# NOTAS DE SEGURANÇA
# ============================================
#
# 1. NUNCA commite este arquivo com valores reais
# 2. Use senhas diferentes para cada ambiente
# 3. Rotacione secrets periodicamente
# 4. Mantenha backup seguro dos secrets
# 5. Use gerenciador de secrets em produção (ex: AWS Secrets Manager)
#
# ============================================
