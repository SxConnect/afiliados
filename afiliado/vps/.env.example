# Configuração da VPS Simulada

# Porta do servidor
VPS_PORT=4000

# Ambiente (development, production)
NODE_ENV=production

# JWT Secret (deve ser o mesmo do Core Engine)
# Gere um secret seguro: openssl rand -base64 32
JWT_SECRET=seu-secret-super-seguro-aqui-mude-em-producao

# Chave Privada RSA (em produção, usar chave real)
# Gere uma chave: openssl genrsa 2048
PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----
MIIEpAIBAAKCAQEA0Z6Lqx...
-----END RSA PRIVATE KEY-----
