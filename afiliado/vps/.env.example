# Environment Configuration
NODE_ENV=production
PORT=3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# RSA Keys (Base64 encoded)
# Generate with: node scripts/generate-keys.js
RSA_PRIVATE_KEY=your-base64-encoded-private-key
RSA_PUBLIC_KEY=your-base64-encoded-public-key

# License Configuration
LICENSE_SECRET=your-license-secret-key-change-this

# Database (opcional - para persistência futura)
DATABASE_URL=postgresql://user:password@localhost:5432/afiliado_db

# Logging
LOG_LEVEL=info

# CORS (opcional)
CORS_ORIGIN=*

# Rate Limiting (opcional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
