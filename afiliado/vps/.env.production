# ========================================
# Configuração de Produção - VPS Afiliados
# ========================================

# ----------------------------------------
# JWT Secret (OBRIGATÓRIO)
# ----------------------------------------
# Gere um secret seguro: openssl rand -base64 32
# IMPORTANTE: Deve ser o mesmo do Core Engine
JWT_SECRET=seu-secret-super-seguro-mude-em-producao

# ----------------------------------------
# RSA Keys
# ----------------------------------------
# Chave Privada RSA para assinatura
# Gere: openssl genrsa 2048 > private.pem
PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
MIIEpAIBAAKCAQEA...
-----END RSA PRIVATE KEY-----"

# ----------------------------------------
# PostgreSQL Database
# ----------------------------------------
# Senha do banco de dados
DB_PASSWORD=mude-esta-senha-postgres-em-producao

# Connection String completa
DATABASE_URL=postgresql://afiliados_vps_user:${DB_PASSWORD}@afiliados_vps_postgres:5432/afiliados_vps_licenses

# ----------------------------------------
# Redis Cache & Queue
# ----------------------------------------
# Senha do Redis
REDIS_PASSWORD=mude-esta-senha-redis-em-producao

# Connection String completa
REDIS_URL=redis://:${REDIS_PASSWORD}@afiliados_vps_redis:6379

# Cache TTL (segundos)
CACHE_TTL=3600

# ----------------------------------------
# Domínio (Traefik)
# ----------------------------------------
VPS_DOMAIN=vps.afiliados.sxconnect.com.br

# ----------------------------------------
# Redis Commander (opcional)
# ----------------------------------------
REDIS_COMMANDER_PASSWORD=admin123

# Basic Auth (htpasswd format)
# Gere: echo $(htpasswd -nb admin senha) | sed -e s/\\$/\\$\\$/g
REDIS_COMMANDER_HTPASSWD=admin:$$apr1$$...
