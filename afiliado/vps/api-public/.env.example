# API Public Environment Variables

# Server
NODE_ENV=production
PORT=4000
CORS_ORIGIN=*

# Database
DB_HOST=afiliados_vps_postgres
DB_PORT=5432
DB_NAME=afiliados_vps_licenses
DB_USER=afiliados_vps_user
DB_PASSWORD=your-db-password
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_SSL=false

# RSA Keys (or use files in shared/keys/)
RSA_PRIVATE_KEY=
RSA_PUBLIC_KEY=

# Fingerprint
FINGERPRINT_SALT=your-unique-salt-change-in-production

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=false
LOG_DIR=./logs

# Rate Limiting (optional overrides)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
