# ========================================
# PRODUCTION CONFIGURATION - 10K USERS
# ========================================

# Environment
NODE_ENV=production
PORT=3000
WORKERS=2

# ========================================
# SECRETS
# ========================================
JWT_SECRET=<GENERATE_WITH: openssl rand -base64 32>
LICENSE_SECRET=<GENERATE_WITH: openssl rand -base64 32>

# ========================================
# DATABASE - PostgreSQL
# ========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=afiliados_vps_licenses
DB_USER=afiliados_vps_user
DB_PASSWORD=<STRONG_PASSWORD>

# Pool Configuration (2 instâncias x 20 conexões = 40 total)
DB_POOL_MAX=20
DB_POOL_MIN=5

# PostgreSQL deve ter max_connections >= 100
# Recomendado: max_connections = 100

# ========================================
# REDIS - Cache
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<STRONG_PASSWORD>

# Cache TTL (segundos)
CACHE_TTL=300

# ========================================
# RATE LIMITING
# ========================================
# 1000 req/min por IP = ~16.67 req/s
# Ajustar conforme necessário

# ========================================
# MONITORING
# ========================================
# Habilitar logs de slow queries
LOG_SLOW_QUERIES=true
SLOW_QUERY_THRESHOLD=200

# ========================================
# NOTAS IMPORTANTES
# ========================================
# 1. Gere novas secrets para produção
# 2. Use senhas fortes para DB e Redis
# 3. Configure PostgreSQL max_connections >= 100
# 4. Configure Redis maxmemory-policy allkeys-lru
# 5. Monitore uso de CPU, RAM e conexões
