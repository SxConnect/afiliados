# Webhook API Environment Variables

# Server
NODE_ENV=production
PORT=4002

# Database
DB_HOST=afiliados_vps_postgres
DB_PORT=5432
DB_NAME=afiliados_vps_licenses
DB_USER=afiliados_vps_user
DB_PASSWORD=your-db-password

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=your-mercadopago-access-token
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret

# Stripe (future)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_DIR=./logs

# Grace Period
GRACE_PERIOD_DAYS=3
