# Configuração do Core Engine
PORT=3001
NODE_ENV=development

# URL da VPS de Validação
VPS_URL=https://sua-vps.com/api
VPS_PUBLIC_KEY=sua-chave-publica-aqui

# Configuração da API PAPI (WhatsApp)
PAPI_URL=http://localhost:3000/api
PAPI_API_KEY=sua-chave-papi-aqui

# JWT Secret para tokens internos
JWT_SECRET=seu-secret-super-seguro-aqui

# Configuração de Quota
DEFAULT_QUOTA_FREE=10
DEFAULT_QUOTA_BASIC=100
DEFAULT_QUOTA_GROWTH=500
DEFAULT_QUOTA_PRO=999999
